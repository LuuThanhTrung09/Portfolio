{
  "extends": ["development"],
  "hints": {
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off",
        "link-name": "off",
      },
    ],
    "axe/structure": [
      "default",
      {
        "list": "off",
      },
    ],
    "no-inline-styles": "off",
    "button-type": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": ["user-select", "backdrop-filter", "min-height: auto"],
      },
    ],
  },
}
